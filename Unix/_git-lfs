#
#  Completion script for git-lfs 3.6.1 (https://github.com/git-lfs/git-lfs)
#
# ------------------------------------------------------------------------------

_git-lfs() {
  local context state state_descr line
  typeset -A opt_args
  local ret=1

  _arguments -C \
    '(- : *)'{-h,--help}'[show help message]' \
    '(- : *)'{-v,--version}'[show version number]' \
    '1: :_git-lfs_commands' \
    '*:: :->subcmd' && ret=0

  case $state in
    (subcmd)
      case $words[1] in
        (checkout)
          _arguments \
            '--base[Check out the merge base of the specified file]' \
            '--ours[Check out our side of the conflict for the specified file]' \
            '--theirs[Check out their side of the conflict for the specified file]' \
            '--to[Check out the portion of the conflict specified by --base, --ours, or --theirs to the given path]:path:_files' \
            '*:: :_files' \
            && ret=0
          ;;
        (completion)
          _arguments \
            '1:shell:(bash fish zsh)' \
            && ret=0
            ;;
        (ext)
          _arguments \
            '1:action:(list)' \
            '*:: :name' \
            && ret=0
          ;;
        (fetch)
          _arguments \
            '(-I --include)'{-I,--include=}'[Specify lfs.fetchinclude just for this invocation]:paths:_files' \
            '(-X --exclude)'{-X,--exclude=}'[Specify lfs.fetchexclude just for this invocation]:paths:_files' \
            '--recent[Download objects referenced by recent branches & commits in addition to those]' \
            '--all[Download all objects that are referenced by any commit reachable from the refs provided as arguments]' \
            '(-p --prune)'{-p,--prune}'[Prune old and unreferenced objects after fetching]' \
            '*:: :__git_objects' \
            && ret=0
          ;;
        (fsck)
          _arguments \
            '--objects[Check that each object in HEAD matches its expected hash]' \
            '--pointers[Check that each pointer is canonical and that each file]' \
            '*:: :__git_objects' \
            && ret=0
          ;;
        (install)
          _arguments \
            '--force[Sets the "lfs" smudge and clean filters, overwriting existing values]' \
            "--local[Sets the 'lfs' smudge and clean filters in the local repository's git config]" \
            "--worktree[Sets the 'lfs' smudge and clean filters in the current working tree's git config]" \
            '--manual[Print instructions for manually updating your hooks to include git-lfs functionality]' \
            '--system[Sets the "lfs" smudge and clean filters in the system git config]' \
            '--skip-smudge[Skips automatic downloading of objects on clone or pull]' \
            '--skip-repo[Skips installation of hooks into the local repository]' \
            && ret=0
          ;;
        (lock)
          _arguments \
            '(-r --remote)'{-r,--remote=}'[Specify the Git LFS server to use]:name' \
            '--json[Write lock info as JSON to STDOUT if the command exits successfully]' \
            '*:: :_files' \
            && ret=0
          ;;
        (locks)
          _arguments \
            '(-r --remote)'{-r,--remote=}'[Specify the Git LFS server to use]:name' \
            '(-i --id)'{-i,--id=}'[Specify a lock by its ID]:id' \
            '(-p --path)'{-p,--path=}'[Specify a lock by its path]:file:_files' \
            '--local[Lists only our own locks which are cached locally]' \
            '--cached[Lists cached locks from the last remote call]' \
            '--verify[Verifies the lock owner on the server and marks our own locks by "O"]' \
            '(-l --limit)'{-l,--limit=}'[Specify number of results to return]:number' \
            '--json[Write lock info as JSON to STDOUT if the command exits successfully]' \
            && ret=0
          ;;
        (logs)
          _git-lfs_logs_commands && ret=0
          ;;
        (ls-files)
          _arguments \
            '(-l --long)'{-l,--long}'[Show the entire 64 character OID, instead of just first 10]' \
            '(-s --size)'{-s,--size}'[Show the size of the LFS object between parenthesis at the end of a line]' \
            '(-d --debug)'{-d,--debug}'[Show as much information as possible about a LFS file]' \
            '(-a --all)'{-a,--all}'[Inspects the full history of the repository, not the current HEAD]' \
            '--deleted[Shows the full history of the given reference, including objects that have been deleted]' \
            '(-I --include)'{-I,--include=}'[Include paths matching only these patterns]:paths:_files' \
            '(-X --exclude)'{-X,--exclude=}'[Exclude paths matching any of these patterns]:paths:_files' \
            '(-n --name-only)'{-n,--name-only}'[Show only the lfs tracked file names]' \
            '*:: :__git_objects' \
            && ret=0
          ;;
        (migrate)
          _arguments \
            '(-I --include)'{-I,--include=}'[Include glob pattern]:paths:_files' \
            '(-X --exclude)'{-X,--exclude=}'[Exclude glob pattern]:paths:_files' \
            '--include-ref[Include reference name]:refname:__git_references' \
            '--exclude-ref[Exclude reference name]:refname:__git_references' \
            '--skip-fetch[Skip fetch]' \
            '--everything[Check in every branch]' \
            '--yes[Assume a yes answer to any prompts, permitting noninteractive use]' \
            '*::branch:__git_branch_names' \
            && ret=0
          ;;
        (prune)
          _arguments \
            '(-d --dry-run)'{-d,--dry-run}'[Do not actually delete anything]' \
            '(-f --force)'{-f,--force}'[Prune all objects except unpushed objects]' \
            '--recent[Prune "recent" commits too]' \
            '(-c --verify-remote)'{-c,--verify-remote}'[Contact the remote and check that copies of reachable files we would delete]' \
            '--no-verify-remote[Disable remote verification if lfs.pruneverifyremotealways was enabled in settings]' \
            '(--verify-reachable --no-verify-reachable)--verify-reachable[When doing --verify-remote contact the remote and check unreachable objects as well]' \
            '(--verify-reachable --no-verify-reachable)--no-verify-reachable[Disables remote verification of unreachable files if lfs.pruneverifyunreachablealways was enabled in settings]' \
            '--when-unverified[Halt the execution or continue the deletion of verified objects]:type:(halt continue)' \
            '(-v --verbose)'{-v,--verbose}'[Report the full detail of what is/would be deleted]' \
            && ret=0
          ;;
        (pull)
          _arguments \
            '(-I --include)'{-I,--include=}'[Specify lfs.fetchinclude just for this invocation]:paths:_files' \
            '(-X --exclude)'{-X,--exclude=}'[Specify lfs.fetchexclude just for this invocation]:paths:_files' \
            '*:: :__git_remotes' \
            && ret=0
          ;;
        (push)
          _arguments \
            '--dry-run[Print the files that would be pushed, without actually pushing them]' \
            '--all[Push all objects to the remote that are referenced by any commit]' \
            '--object-id[Push only the object OIDs]:remote:__git_remotes' \
            '--stdin[Read a list of newline-delimited refs from standard input]' \
            && ret=0
          ;;
        (status)
          _arguments \
            '(--porcelain --json)--porcelain[Give the output in an easy-to-parse format for scripts]' \
            '(--porcelain --json)--json[Give the output in a stable json format for scripts]' \
            && ret=0
          ;;
        (track)
          _arguments \
            '(-v --verbose)'{-v,--verbose}'[If enabled, have git lfs track log files which it will touch]' \
            '(-d --dry-run)'{-d,--dry-run}'[Dry run]' \
            '--file-name[Treat the arguments as literal filenames, not as patterns]' \
            '(-l --lockable --not-lockable)'{-l,--lockable}'[Make the paths "lockable", meaning they should be locked to edit them]' \
            '(-l --lockable --not-lockable)--not-lockable[Remove the lockable flag from the paths so they are no longer read-only]' \
            '--no-excluded[Do not list patterns that are excluded in the output]' \
            '--no-modify-attrs[Makes matched entries stat-dirty so that Git can re-index files you wish to convert to LFS]' \
            '*::pattern:_files' \
            && ret=0
          ;;
        (uninstall)
          _arguments \
            '--local[Removes the "lfs" smudge and clean filters from the local repository]' \
            "--worktree[Removes the 'lfs' smudge and clean filters from the current working tree's git config]" \
            '--system[Removes the "lfs" smudge and clean filters from the system git config]' \
            '--skip-repo[Skip cleanup of the local repo]' \
            && ret=0
          ;;
        (unlock)
          _arguments \
            '(-r --remote)'{-r,--remote=}'[Specify the Git LFS server to use]:name' \
            '(-f --force)'{-f,--force}"[Tell the server to remove the lock, even if it's owned by another user]" \
            '(-d --id)'{-i,--id=}'[Specify a lock by its ID instead of path]:id' \
            '--json[Write lock info as JSON to STDOUT if the command exits successfully]' \
            '*:: :_files' \
            && ret=0
          ;;
        (update)
          _arguments \
            '(-m --manual)'{-m,--manual}'[Print instructions for manually updating your hooks]' \
            '(-f --force)'{-f,--force}'[Forcibly overwrite any existing hooks with git-lfs hooks]' \
            && ret=0
          ;;
      esac
    ;;
  esac

  return ret
}

(( $+functions[_git-lfs_commands] )) ||
_git-lfs_commands() {
  local -a commands=(
    "checkout:Populate working copy with real content from Git LFS files"
    "completion:Generate shell scripts for command-line tab-completion of Git LFS commands"
    "dedup:De-duplicate Git LFS files"
    "env:Display the Git LFS environment"
    "ext:Display Git LFS extension details"
    "fetch:Download Git LFS files from a remote"
    "fsck:Check Git LFS files for consistency"
    "install:Install Git LFS configuration"
    "lock:Set a file as 'locked' on the Git LFS server"
    "locks:List currently 'locked' files from the Git LFS server"
    "logs:Show errors from the Git LFS command"
    "ls-files:Show information about Git LFS files in the index and working tree"
    "migrate:Migrate history to or from Git LFS"
    "prune:Delete old Git LFS files from local storage"
    "pull:Fetch Git LFS changes from the remote & checkout any required working tree files"
    "push:Push queued large files to the Git LFS endpoint"
    "status:Show the status of Git LFS files in the working tree"
    "track:View or add Git LFS paths to Git attributes"
    "uninstall:Uninstall Git LFS by removing hooks and smudge/clean filter configuration"
    "unlock:Remove 'locked' setting for a file on the Git LFS server."
    "untrack:Remove Git LFS paths from Git Attributes"
    "update:Update Git hooks for the current Git repository"
    "version:Report the version number"
    # Low level plumbing commands
    "clean:Git clean filter that converts large files to pointers"
    "filter-process:Git process filter that converts between large files and pointers"
    "merge-driver:Merge text-based LFS files"
    "pointer:Build and compare pointers"
    "post-checkout:Git post-checkout hook implementation"
    "post-commit:Git post-commit hook implementation"
    "post-merge:Git post-merge hook implementation"
    "pre-push:Git pre-push hook implementation"
    "smudge:Git smudge filter that converts pointer in blobs to the actual content"
    "standalone-file:Git LFS standalone transfer adapter for file URLs (local paths)"
  )

  _describe -t 'commands' "commands" commands
}

(( $+functions[_git-lfs_logs_commands] )) ||
_git-lfs_logs_commands() {
  local -a commands=(
    "clear:Clear all of the existing logged errors"
    "boomtown:Trigger a dummy exception"
    "last:Show the most recent error"
  )

  _alternative \
    'command: : _describe -t commands commands commands' \
    'file: : _files'
}

_git-lfs "$@"

